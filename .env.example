# ─────────────────────────────────────────────────────────────────────────────
# SOS Maintenance — example environment. Copy to `.env` and fill per environment.
# NEVER commit real secrets. This file must contain placeholders only.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
TZ=Asia/Bangkok

# Database (PostgreSQL + PostGIS)
# In Docker Compose the host is `postgres`; for host-run dev use localhost.
DATABASE_URL=postgresql://sos:sos@localhost:5432/sos?schema=public

# Authentication mode. `internal` disables login for a trusted internal network.
# The deployment must not be reachable from the public internet in this mode.
AUTH_MODE=internal

# Optional Keycloak (OIDC + TOTP MFA) mode — used only when AUTH_MODE=keycloak.
KEYCLOAK_ISSUER=http://localhost:8080/realms/sos
KEYCLOAK_CLIENT_ID=sos-web
KEYCLOAK_CLIENT_SECRET=__set_me__
AUTH_SECRET=__generate_a_long_random_string__

# Legacy DEV-ONLY auth bypass: when 'true', the server reads roles from the
# `x-dev-roles` request header (comma-separated, e.g. TECHNICIAN,PLANNER) instead
# of a real OIDC session. Lets APIs be exercised before the OIDC provider is
# wired. MUST stay unset/false in any shared or production environment.
AUTH_DEV_BYPASS=false

# SMTP (Nodemailer) — organisation mail server, no paid provider
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ระบบซ่อมบำรุงเสา SOS <no-reply@example.local>"

# File storage (private volume in V1; S3-compatible later — no domain change)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./var/uploads
UPLOAD_MAX_BYTES=15728640
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf

# Map (OpenStreetMap online tiles; configurable provider + attribution)
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors

# Readiness / policy
READINESS_GRACE_DAYS=7
GPS_EXCEPTION_METERS=100

# Backup
BACKUP_DIR=./var/backup
BACKUP_RETENTION_DAYS=30

# Feature / adapter flags
ADAPTER_SNMP_ENABLED=false
ADAPTER_HEALTH_API_ENABLED=false
