# Production env template for docker-compose.prod.yml.
# Copy to `.env.prod` (gitignored), fill with REAL secrets, keep off version control.

APP_DOMAIN=sos.example.go.th
APP_BASE_URL=https://sos.example.go.th

# Database
POSTGRES_USER=sos
POSTGRES_PASSWORD=__strong_password__
POSTGRES_DB=sos
DATABASE_URL=postgresql://sos:__strong_password__@postgres:5432/sos?schema=public

# Keycloak
KC_DB_URL=jdbc:postgresql://postgres:5432/sos
KC_HOSTNAME=sos.example.go.th
KC_ADMIN=admin
KC_ADMIN_PASSWORD=__strong_admin_password__
KEYCLOAK_ISSUER=https://sos.example.go.th/auth/realms/sos
KEYCLOAK_CLIENT_ID=sos-web
KEYCLOAK_CLIENT_SECRET=__from_keycloak__
AUTH_SECRET=__long_random_string__

# SMTP (organisation mail server)
SMTP_HOST=smtp.example.go.th
SMTP_PORT=587
SMTP_FROM="ระบบซ่อมบำรุงเสา SOS <no-reply@example.go.th>"

# Backup
BACKUP_RETENTION_DAYS=30
